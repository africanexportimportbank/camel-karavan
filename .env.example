# Copy this file to `.env` (gitignored) and fill in your values.
# The Makefile loads it automatically (`-include .env`). Keep real secrets and
# account identifiers ONLY in .env — never in the committed Makefile.

# Auth0 OIDC client credentials — used by `make oidc-secret`, deploy-oidc, deploy-eks.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Container registry for built project/app images.
#   local:  localhost:5005
#   AWS:    <account-id>.dkr.ecr.<region>.amazonaws.com/<group>
REGISTRY=localhost:5005

# AWS CLI profile for ECR auth (leave empty to use the default credential chain).
AWS_PROFILE=

# EKS kube-context that `make deploy-eks` targets (it never uses your current context):
#   arn:aws:eks:<region>:<account-id>:cluster/<cluster-name>
EKS_CONTEXT=

# Public URL the app is served at on EKS (domain-specific). Printed after deploy-eks.
#   e.g. https://karavan.<your-domain>
APP_URL=
